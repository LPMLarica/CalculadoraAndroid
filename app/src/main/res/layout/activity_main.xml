<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:columnCount="4"
    android:padding="8dp">

    <TextView
        android:id="@+id/visor"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_columnSpan="4"
        android:text="0"
        android:textSize="36sp"
        android:gravity="end|bottom"
        android:padding="16dp"
        android:background="#DDDDDD" />

    <Button android:id="@+id/btnRaiz" android:text="√"/>
    <Button android:id="@+id/btnQuadrado" android:text="x²"/>
    <Button android:id="@+id/btnPorcentagem" android:text="%"/>
    <Button android:id="@+id/btnDividir" android:text="/"/>

    <Button android:id="@+id/btn7" android:text="7"/>
    <Button android:id="@+id/btn8" android:text="8"/>
    <Button android:id="@+id/btn9" android:text="9"/>
    <Button android:id="@+id/btnMultiplicar" android:text="*"/>

    <Button android:id="@+id/btn4" android:text="4"/>
    <Button android:id="@+id/btn5" android:text="5"/>
    <Button android:id="@+id/btn6" android:text="6"/>
    <Button android:id="@+id/btnMenos" android:text="-"/>

    <Button android:id="@+id/btn1" android:text="1"/>
    <Button android:id="@+id/btn2" android:text="2"/>
    <Button android:id="@+id/btn3" android:text="3"/>
    <Button android:id="@+id/btnMais" android:text="+"/>

    <Button android:id="@+id/btn0" android:text="0"/>
    <Button android:id="@+id/btnLimpar" android:text="C"/>
    <Button android:id="@+id/btnIgual" android:text="="/>

</GridLayout>